# Copy to .env and fill in values
# Fixer.io API key — get one free at https://fixer.io/
# Leave blank to use synthetic seed data (fully demoable without a key)
FIXER_API_KEY=

# Ollama model for trend insights (must be pulled first: ollama pull llama3.2)
OLLAMA_MODEL=llama3.2

# Postgres (override if running Postgres outside docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/exchange
SPRING_DATASOURCE_USERNAME=exchange
SPRING_DATASOURCE_PASSWORD=exchange
