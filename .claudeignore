# Real env files — only .env.example is safe to read
.env
.env.*
!.env.example

# Spring profile configs that may carry real credentials (stage / prod)
**/application-stage*.yml
**/application-stage*.yaml
**/application-prod*.yml
**/application-prod*.yaml
**/application-production*.yml
**/application-production*.yaml

# Certificate and key material
**/*.pem
**/*.key
**/*.p12
**/*.jks
**/*.keystore
**/*.pfx
**/*.cer
**/*.crt

# Generic credential / secret files
**/*credential*
**/*credentials*
**/*secret.yml
**/*secret.yaml
**/*secret.json
**/*.token
**/.tokens

# Local Claude settings (may contain API tokens or personal config)
.claude/settings.local.json
